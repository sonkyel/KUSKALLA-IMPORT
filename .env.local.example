# Analítica (opcional). Copia este archivo a .env.local y pega tus IDs.
# Sin estas variables, la web funciona igual pero no rastrea visitas.

# Google Analytics 4 — formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Meta (Facebook/Instagram) Pixel — solo el número de ID
NEXT_PUBLIC_META_PIXEL_ID=

# Google Search Console — token de verificación (etiqueta meta)
# Lo obtienes en search.google.com/search-console al verificar el dominio.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
